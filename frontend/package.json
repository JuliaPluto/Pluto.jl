{
  "name": "@plutojl/rainbow",
  "version": "0.6.21",
  "description": "TypeScript/JavaScript API for programmatically interacting with Pluto notebooks",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/standalone/index.d.ts",
  "ui-main": "dist/ui.cjs",
  "ui-module": "dist/ui.mjs",
  "react-main": "dist/react.cjs",
  "react-module": "dist/react.mjs",
  "source": "standalone/index.js",
  "files": [
    "dist",
    "standalone/integrations/node-polyfill.js"
  ],
  "workspaces": [
    "parcel-resolver-like-a-browser"
  ],
  "scripts": {
    "build": "npm run clean && npm run build:rainbow && npm run build:editor",
    "build:editor": "parcel build --no-source-maps --target pluto",
    "build:rainbow": "parcel build --no-source-maps --target main --target module --target ui-main --target ui-module --target react-main --target react-module && npm run build:types",
    "build:types": "mkdir -p dist/standalone/integrations && cp standalone/index.d.ts dist/standalone/index.d.ts && cp standalone/integrations/react.d.ts dist/standalone/integrations/react.d.ts",
    "start": "parcel --target pluto",
    "clean": "rm -rf dist ../frontend-dist",
    "prepublishOnly": "npm run build:rainbow",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "pluto",
    "julia",
    "notebook",
    "api",
    "typescript"
  ],
  "author": "Pluto.jl Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/fonsp/Pluto.jl.git",
    "directory": "frontend"
  },
  "engines": {
    "node": ">=22 <23",
    "npm": ">=10 <11"
  },
  "targets": {
    "pluto": {
      "source": [
        "index.html",
        "editor.html",
        "error.jl.html"
      ],
      "distDir": "../frontend-dist",
      "publicUrl": ".",
      "context": "browser"
    },
    "main": {
      "isLibrary": true,
      "outputFormat": "commonjs",
      "context": "browser",
      "includeNodeModules": {
        "react": false,
        "react-dom": false
      }
    },
    "module": {
      "isLibrary": true,
      "outputFormat": "esmodule",
      "context": "browser",
      "includeNodeModules": {
        "react": false,
        "react-dom": false
      }
    },
    "ui-main": {
      "source": "ui.ts",
      "isLibrary": true,
      "outputFormat": "commonjs",
      "context": "browser",
      "includeNodeModules": {
        "react": false,
        "react-dom": false
      }
    },
    "ui-module": {
      "source": "ui.ts",
      "isLibrary": true,
      "outputFormat": "esmodule",
      "context": "browser",
      "includeNodeModules": {
        "react": false,
        "react-dom": false
      }
    },
    "react-main": {
      "source": "standalone/integrations/react.js",
      "isLibrary": true,
      "outputFormat": "commonjs",
      "context": "browser",
      "includeNodeModules": {
        "react": false,
        "react-dom": false
      }
    },
    "react-module": {
      "source": "standalone/integrations/react.js",
      "isLibrary": true,
      "outputFormat": "esmodule",
      "context": "browser",
      "includeNodeModules": {
        "react": false,
        "react-dom": false
      }
    }
  },
  "exports": {
    ".": {
      "types": "./dist/standalone/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.mjs"
    },
    "./node-polyfill": {
      "default": "./standalone/integrations/node-polyfill.js"
    },
    "./react": {
      "types": "./dist/standalone/integrations/react.d.ts",
      "import": "./dist/react.mjs",
      "require": "./dist/react.cjs",
      "default": "./dist/react.mjs"
    },
    "./ui": {
      "import": "./dist/ui.mjs",
      "require": "./dist/ui.cjs",
      "default": "./dist/ui.mjs"
    }
  },
  "devDependencies": {
    "@highlightjs/cdn-assets": "^11.11.1",
    "@parcel/config-default": "~2.12.0",
    "@parcel/optimizer-blob-url": "~2.12.0",
    "@parcel/optimizer-data-url": "~2.12.0",
    "@parcel/transformer-typescript-tsc": "~2.12.0",
    "@plutojl/posthtml-crossorigin": "^1.0.0",
    "@types/lodash-es": "^4.17.6",
    "@types/node": "^22",
    "@types/react": "^19.1.10",
    "@types/ws": "^8.18.1",
    "parcel": "~2.12.0",
    "parcel-reporter-bundle-manifest": "^1.0.0",
    "parcel-resolver-like-a-browser": "*",
    "posthtml": "^0.16.6",
    "posthtml-sri": "^2.0.0",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "@observablehq/stdlib": "^3.3.1",
    "immer": "^10.1.3",
    "linkedom": "^0.18.12",
    "lodash-es": "^4.17.21",
    "msgpack-lite": "github:fonsp/msgpack-lite#0.1.27-es.1",
    "requestidlecallback-polyfill": "^1.0.2",
    "seamless-scroll-polyfill": "^2.3.4",
    "vmsg": "^0.4.0",
    "ws": "^8.18.3"
  },
  "peerDependencies": {
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  }
}
